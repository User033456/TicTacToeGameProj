<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="TicTacToeGameProj.ColorPickerPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:Maui.ColorPicker;assembly=Maui.ColorPicker"
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent">

    <Grid BackgroundColor="Transparent">
        <Frame CornerRadius="25"
               BackgroundColor="#D9D9D9"
               BorderColor="#D9D9D9"
               HasShadow="True"
               Padding="16,12"
               WidthRequest="280"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="12" >

                <Label Grid.Row="0"
                       Text="Choose color"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#020136"
                       HorizontalOptions="Center"/>

                <Frame Grid.Row="1"
                       CornerRadius="20"
                       Padding="0"
                       HasShadow="False"
                       IsClippedToBounds="True"
                       BorderColor="Transparent"
                       BackgroundColor="Transparent">

                    <controls:ColorPicker
                        x:Name="MainColorPicker"
                        HeightRequest="220"
                        HorizontalOptions="Fill"
                        ColorFlowDirection="Horizontal"
                        ColorSpectrumStyle="ShadeToHueStyle"
                        PointerRingBorderUnits="0.3"
                        PointerRingDiameterUnits="0.7" />

                </Frame>

                <Frame Grid.Row="2"
                       Padding="0"
                       HeightRequest="50"
                       WidthRequest="50"
                       CornerRadius="25"
                       BorderColor="Transparent"
                       BackgroundColor="Transparent"
                       HasShadow="False"
                       HorizontalOptions="Center">
                    <BoxView x:Name="PreviewBox" 
                             Color="Red"
                             CornerRadius="25"/>
                </Frame>

                <HorizontalStackLayout Grid.Row="3"
                                       HorizontalOptions="End"
                                       Spacing="10">
                    <Button Text="Apply"
                            BackgroundColor="#020136"
                            TextColor="White"
                            CornerRadius="18"
                            Padding="16,4"
                            Clicked="OnApplyClicked"/>

                    <Button Text="Close"
                            BackgroundColor="#D9D9D9"
                            BorderColor="#020136"
                            BorderWidth="1"
                            TextColor="#020136"
                            CornerRadius="18"
                            Padding="16,4"
                            Clicked="OnCloseClicked"/>
                </HorizontalStackLayout>
            </Grid>
        </Frame>
    </Grid>
</toolkit:Popup>